{
  "name": "@m2s2/react-lib",
  "version": "2.9.1",
  "description": "React component library by M²S² Engineering Group.",
  "author": "M²S² Engineering Group <contact@m2s2.io>",
  "license": "MIT",
  "keywords": [
    "react",
    "component-library",
    "ui",
    "m2s2"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/M2S2-Engineering-Group/m2s2-design-system",
    "directory": "packages/react-lib"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/react-lib.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "build:prod": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6007",
    "build:storybook": "storybook build -o ../../dist/storybook/react"
  },
  "dependencies": {
    "@m2s2/models": "2.5.0",
    "@m2s2/tokens": "2.2.2",
    "@m2s2/utils": "1.1.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-visually-hidden": "^1.1.1",
    "chart.js": "^4.5.1",
    "marked": "^17.0.0"
  },
  "peerDependencies": {
    "aws-amplify": ">=6.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    },
    "aws-amplify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.6",
    "axe-core": "^4.10.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "react-router": "^7.18.1",
    "sass": "^1.89.0",
    "storybook": "^10.3.6",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.6"
  }
}
