{
  "name": "@m2s2/ng-lib",
  "version": "1.0.0",
  "description": "Angular component library by M²S² Engineering Group — production-ready UI components built with signals and standalone architecture.",
  "author": "M²S² Engineering Group <contact@m2s2.io>",
  "license": "MIT",
  "keywords": [
    "angular",
    "component-library",
    "ui",
    "standalone",
    "signals",
    "m2s2"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/M2S2-Engineering-Group/m2s2-design-system",
    "directory": "packages/ng-lib"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cd ../.. && ng build --project=m2s2-ng-lib",
    "build:prod": "cd ../.. && ng build --project=m2s2-ng-lib -c production",
    "test": "cd ../.. && ng test --project=m2s2-ng-lib",
    "storybook": "cd ../.. && ng run m2s2-ng-lib:storybook",
    "build:storybook": "cd ../.. && ng run m2s2-ng-lib:build-storybook"
  },
  "dependencies": {
    "tslib": "~2.3.1"
  },
  "peerDependencies": {
    "@m2s2/models": ">=0.1.0",
    "@m2s2/tokens": ">=0.1.0",
    "@angular/animations": ">=21.0.0",
    "@angular/cdk": ">=21.0.0",
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/material": ">=21.0.0",
    "@angular/router": ">=21.0.0"
  },
  "devDependencies": {
    "aws-amplify": "^6.14.3",
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.9",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/angular": "^10.3.6",
    "@types/jest": "^30.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "ng-packagr": "^21.2.2",
    "storybook": "^10.3.6",
    "typescript": "~5.9.3"
  }
}
