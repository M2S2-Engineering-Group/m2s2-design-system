{
  "name": "m2s2-design-system",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "storybook": "storybook dev -p 6009 --config-dir .storybook",
    "storybook:angular": "npm run storybook --workspace=packages/ng-lib",
    "storybook:react": "npm run storybook --workspace=packages/react-lib",
    "storybook:vue": "npm run storybook --workspace=packages/vue-lib",
    "storybook:refs": "concurrently --prefix-colors \"bgBlue.bold,bgMagenta.bold,bgGreen.bold,bgCyan.bold\" --names \"angular,react,wc,vue\" \"npm run storybook:angular\" \"npm run storybook:react\" \"npm run storybook:vue\"",
    "storybook:all": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgMagenta.bold,bgGreen.bold,bgCyan.bold,bgYellow.bold\" --names \"angular,react,wc,vue,composed\" \"npm run storybook:angular\" \"npm run storybook:react\" \"npm run storybook:vue\" \"npm run storybook\"",
    "build:storybook": "STORYBOOK_ANGULAR_URL=/angular STORYBOOK_REACT_URL=/react STORYBOOK_VUE_URL=/vue storybook build --config-dir .storybook -o dist/storybook && turbo run build:storybook",
    "prepare": "husky"
  },
  "overrides": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/html-vite": "^10.3.6",
    "concurrently": "^9.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "multi-semantic-release": "^3.0.2",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.6",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "turbo": "^2.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.3.5",
    "vue-eslint-parser": "^10.4.1"
  }
}
