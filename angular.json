{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "packages",
  "projects": {
    "m2s2-ng-lib": {
      "projectType": "library",
      "root": "packages/ng-lib",
      "sourceRoot": "packages/ng-lib/src",
      "prefix": "m2s2",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "packages/ng-lib/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "packages/ng-lib/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "packages/ng-lib/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "tsConfig": "tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "packages/ng-lib/.storybook",
            "browserTarget": "storybook-host:build:storybook",
            "tsConfig": "packages/ng-lib/tsconfig.storybook.json",
            "port": 6006,
            "compodoc": false,
            "styles": ["packages/ng-lib/.storybook/preview.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["packages"]
            }
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "packages/ng-lib/.storybook",
            "browserTarget": "storybook-host:build:storybook",
            "tsConfig": "packages/ng-lib/tsconfig.storybook.json",
            "outputDir": "dist/storybook/angular",
            "compodoc": false,
            "styles": ["packages/ng-lib/.storybook/preview.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["packages"]
            }
          }
        }
      }
    },
    "storybook-host": {
      "projectType": "application",
      "root": "apps/storybook-host",
      "sourceRoot": "apps/storybook-host/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storybook-host",
            "index": "apps/storybook-host/src/index.html",
            "browser": "apps/storybook-host/src/main.ts",
            "tsConfig": "apps/storybook-host/tsconfig.app.json",
            "styles": ["packages/tokens/index.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["packages"]
            }
          },
          "configurations": {
            "storybook": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": false
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
